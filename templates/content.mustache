<div class="mastermind-insights-container">
    <div class="mastermind-insights-header">
        <h3 class="mastermind-insights-title">Insights</h3>
    </div>

    <div class="mastermind-metrics-grid">
        <div class="mastermind-metric-card">
            <div class="mastermind-metric-icon mastermind-icon-completion">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 11L12 14L22 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M21 12V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="mastermind-metric-content">
                <div class="mastermind-metric-label">Completion Rate</div>
                <div class="mastermind-metric-value">{{completionrate}}%</div>
            </div>
        </div>

        <div class="mastermind-metric-card">
            <div class="mastermind-metric-icon mastermind-icon-grade">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="mastermind-metric-content">
                <div class="mastermind-metric-label">Avg Final Grade</div>
                <div class="mastermind-metric-value">{{avggrade}}%</div>
            </div>
        </div>

        <div class="mastermind-metric-card">
            <div class="mastermind-metric-icon mastermind-icon-section">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="mastermind-metric-content">
                <div class="mastermind-metric-label">Drop-off Section</div>
                <div class="mastermind-metric-value mastermind-metric-text">{{dropoffsection}}</div>
            </div>
        </div>

        <div class="mastermind-metric-card">
            <div class="mastermind-metric-icon mastermind-icon-forum">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="mastermind-metric-content">
                <div class="mastermind-metric-label">Forum Activity</div>
                <div class="mastermind-metric-value">{{forumactivity}} <span class="mastermind-metric-unit">posts/learner</span></div>
            </div>
        </div>

        <div class="mastermind-metric-card">
            <div class="mastermind-metric-icon mastermind-icon-time">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 8V12L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M3.05 11C3.27 6.06 7.37 2.13 12.31 2.01C17.56 1.89 21.95 6.06 22 11.31C22.05 16.56 17.88 20.95 12.63 21C10.47 21.02 8.47 20.27 6.9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M4 17L2 22L7 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="mastermind-metric-content">
                <div class="mastermind-metric-label">Last Activity</div>
                <div class="mastermind-metric-value mastermind-metric-text">{{lastactivity}}</div>
            </div>
        </div>

        <div class="mastermind-metric-card">
            <div class="mastermind-metric-icon mastermind-icon-resources">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
                    <rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2"/>
                </svg>
            </div>
            <div class="mastermind-metric-content">
                <div class="mastermind-metric-label">Resources</div>
                <div class="mastermind-metric-value">{{resources}}</div>
            </div>
        </div>
    </div>

    <div id="mastermind-insights-summary" class="mastermind-insights-summary" style="display: none;">
        <div id="mastermind-summary-text" class="mastermind-summary-text"></div>
    </div>

    <div id="ai-progress-container" class="mastermind-progress-container" style="display: none;">
        <div class="mastermind-progress-header">
            <svg class="mastermind-progress-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2V6M12 18V22M4.93 4.93L7.76 7.76M16.24 16.24L19.07 19.07M2 12H6M18 12H22M4.93 19.07L7.76 16.24M16.24 7.76L19.07 4.93" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>AI Analysis Progress</span>
        </div>
        <div id="ai-progress-content" class="mastermind-progress-content">
            <div id="step1-progress" class="mastermind-progress-step">
                <span class="mastermind-step-icon">⏳</span>
                <span class="mastermind-step-text">Analyzing course structure and generating recommendations...</span>
            </div>
            <div id="step2-progress" class="mastermind-progress-step" style="display: none;">
                <span class="mastermind-step-icon">⏳</span>
                <span class="mastermind-step-text">Generating updated course structure...</span>
            </div>
            <div id="step3-progress" class="mastermind-progress-step" style="display: none;">
                <span class="mastermind-step-icon">✅</span>
                <span class="mastermind-step-text">Analysis complete!</span>
            </div>
        </div>
    </div>

    <button id="show-detailed-metrics-btn" class="mastermind-secondary-button">
        <svg class="mastermind-button-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="currentColor"/>
        </svg>
        <span>Show Detailed Metrics</span>
    </button>

    <button id="get-recommendations-btn" class="mastermind-action-button">
        <svg class="mastermind-button-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="currentColor"/>
        </svg>
        <span>{{#str}} getrecommendations, block_mastermind_assistant {{/str}}</span>
    </button>
</div>

