{{!
    @template block_mastermind_assistant/mod_draft

    Template for the Mastermind Assistant mod draft feature.

    Context variables required for this template:
    * courseid - Course ID
    * coursename - Course name
    * modname - Module name (e.g., "Page")
    * pagename - Page name (if editing existing)
    * pagedescription - Page description (if editing existing)
    * is_new - Boolean, true if creating new page
    * ai_status - AI connection status
    * ai_message - AI status message
    * is_ai_success - Boolean, true if AI is connected

    Example context (json):
    {
        "is_mod_draft": true,
        "is_quiz": true,
        "courseid": 2,
        "coursename": "Demo Course",
        "modname": "Quiz",
        "modname_lower": "quiz",
        "pagename": "Module 1 quiz",
        "pagedescription": "",
        "cmid": 12,
        "instanceid": 4,
        "quizid": 12,
        "is_new": false,
        "ai_status": "success",
        "ai_message": "Connected",
        "is_ai_success": true,
        "is_on_edit_page": true,
        "is_direct_action": false,
        "edit_url": "",
        "main_page_url": "",
        "existing_count": 0
    }
}}

<div class="mastermind-mod-draft-container">
    <div class="mastermind-mod-draft-header">
        <svg class="mastermind-mod-draft-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="currentColor"/>
        </svg>
        <h3 class="mastermind-mod-draft-title">{{#str}} ai_content_assistant, block_mastermind_assistant {{/str}}</h3>
    </div>

    {{#is_ai_success}}
    {{! Show intro text when on the correct working page }}
    {{#is_on_edit_page}}
    <div class="mastermind-mod-draft-intro">
        <p class="mastermind-mod-draft-text">
            {{#is_page}}{{^is_new}}{{#str}} draft_page_prompt_edit, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{#is_new}}{{#str}} draft_page_prompt_new, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{/is_page}}
            {{#is_quiz}}{{^is_new}}{{#str}} draft_quiz_prompt_edit, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{#is_new}}{{#str}} draft_quiz_prompt_new, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{/is_quiz}}
            {{#is_assign}}{{^is_new}}{{#str}} draft_assign_prompt_edit, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{#is_new}}{{#str}} draft_assign_prompt_new, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{/is_assign}}
            {{#is_url}}{{^is_new}}{{#str}} draft_url_prompt_edit, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{#is_new}}{{#str}} draft_url_prompt_new, block_mastermind_assistant, {{modname}} {{/str}}{{/is_new}}{{/is_url}}
        </p>
    </div>
    {{/is_on_edit_page}}
    {{! Direct-action modules (Forum/Glossary/Book/Lesson) show on their main pages }}
    {{#is_direct_action}}
    {{^is_on_edit_page}}
    <div class="mastermind-mod-draft-intro">
        <p class="mastermind-mod-draft-text">
            {{#is_forum}}{{#str}} draft_forum_prompt_edit, block_mastermind_assistant, {{modname}} {{/str}}{{/is_forum}}
            {{#is_lesson}}{{#str}} draft_lesson_prompt_new, block_mastermind_assistant, {{modname}} {{/str}}{{/is_lesson}}
            {{#is_glossary}}{{#str}} draft_glossary_prompt_new, block_mastermind_assistant, {{modname}} {{/str}}{{/is_glossary}}
            {{#is_book}}{{#str}} draft_book_prompt_new, block_mastermind_assistant, {{modname}} {{/str}}{{/is_book}}
        </p>
        {{#existing_count}}<p class="mastermind-mod-draft-count">{{#str}} existing_items_count, block_mastermind_assistant, {{existing_count}} {{/str}}</p>{{/existing_count}}
    </div>
    {{/is_on_edit_page}}
    {{#is_on_edit_page}}
    <div class="mastermind-mod-draft-info-box">
        <svg class="mastermind-info-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M12 16V12M12 8H12.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <div class="mastermind-info-content">
            <p class="mastermind-info-text">{{#str}} go_to_main_page_to_generate, block_mastermind_assistant {{/str}}</p>
            <a href="{{main_page_url}}" class="mastermind-settings-link">{{#str}} open_activity_main_page, block_mastermind_assistant {{/str}}</a>
        </div>
    </div>
    {{/is_on_edit_page}}
    {{/is_direct_action}}
    {{! Editor-based modules (Page/Assign/URL) on view page — redirect to settings }}
    {{^is_direct_action}}
    {{^is_on_edit_page}}
    <div class="mastermind-mod-draft-info-box">
        <svg class="mastermind-info-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M12 16V12M12 8H12.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <div class="mastermind-info-content">
            <p class="mastermind-info-text">{{#str}} go_to_settings_to_generate, block_mastermind_assistant {{/str}}</p>
            <a href="{{edit_url}}" class="mastermind-settings-link">{{#str}} open_activity_settings, block_mastermind_assistant {{/str}}</a>
        </div>
    </div>
    {{/is_on_edit_page}}
    {{/is_direct_action}}
    

    <div id="mod-draft-progress-container" class="mastermind-progress-container" style="display: none;">
        <div class="mastermind-progress-header">
            <svg class="mastermind-progress-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2V6M12 18V22M4.93 4.93L7.76 7.76M16.24 16.24L19.07 19.07M2 12H6M18 12H22M4.93 19.07L7.76 16.24M16.24 7.76L19.07 4.93" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span id="progress-message">{{#is_page}}{{#str}} generating_content, block_mastermind_assistant {{/str}}{{/is_page}}{{#is_quiz}}{{#str}} generating_questions, block_mastermind_assistant {{/str}}{{/is_quiz}}{{#is_assign}}{{#str}} generating_content, block_mastermind_assistant {{/str}}{{/is_assign}}{{#is_forum}}{{#str}} generating_forum, block_mastermind_assistant {{/str}}{{/is_forum}}{{#is_lesson}}{{#str}} generating_lesson, block_mastermind_assistant {{/str}}{{/is_lesson}}{{#is_glossary}}{{#str}} generating_glossary, block_mastermind_assistant {{/str}}{{/is_glossary}}{{#is_book}}{{#str}} generating_book, block_mastermind_assistant {{/str}}{{/is_book}}{{#is_url}}{{#str}} generating_url, block_mastermind_assistant {{/str}}{{/is_url}}</span>
        </div>
        <div id="mod-draft-progress-content" class="mastermind-progress-content">
            <div class="mastermind-progress-step">
                <span class="mastermind-step-icon">⏳</span>
                <span class="mastermind-step-text">{{#is_page}}{{#str}} analyzing_context, block_mastermind_assistant {{/str}}{{/is_page}}{{#is_quiz}}{{#str}} analyzing_quiz_context, block_mastermind_assistant {{/str}}{{/is_quiz}}{{#is_assign}}{{#str}} analyzing_context, block_mastermind_assistant {{/str}}{{/is_assign}}{{#is_forum}}{{#str}} analyzing_context, block_mastermind_assistant {{/str}}{{/is_forum}}{{#is_lesson}}{{#str}} analyzing_context, block_mastermind_assistant {{/str}}{{/is_lesson}}{{#is_glossary}}{{#str}} analyzing_context, block_mastermind_assistant {{/str}}{{/is_glossary}}{{#is_book}}{{#str}} analyzing_context, block_mastermind_assistant {{/str}}{{/is_book}}{{#is_url}}{{#str}} analyzing_context, block_mastermind_assistant {{/str}}{{/is_url}}</span>
            </div>
        </div>
    </div>

    {{! Options panels and generate buttons }}
    {{#is_page}}{{#is_on_edit_page}}
    <div class="mastermind-assign-options" id="page-options-panel">
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="page-content-type-select">
                {{#str}} content_type_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="page-content-type-select" class="mastermind-option-select">
                <option value="">{{#str}} select_content_type, block_mastermind_assistant {{/str}}</option>
                <option value="lecture_notes">{{#str}} type_lecture_notes, block_mastermind_assistant {{/str}}</option>
                <option value="tutorial">{{#str}} type_tutorial, block_mastermind_assistant {{/str}}</option>
                <option value="reference">{{#str}} type_reference, block_mastermind_assistant {{/str}}</option>
                <option value="case_study">{{#str}} type_case_study_page, block_mastermind_assistant {{/str}}</option>
                <option value="overview">{{#str}} type_overview, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="page-level-select">
                {{#str}} academic_level_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="page-level-select" class="mastermind-option-select">
                <option value="">{{#str}} select_academic_level, block_mastermind_assistant {{/str}}</option>
                <option value="introductory">{{#str}} level_introductory, block_mastermind_assistant {{/str}}</option>
                <option value="intermediate">{{#str}} level_intermediate, block_mastermind_assistant {{/str}}</option>
                <option value="advanced">{{#str}} level_advanced, block_mastermind_assistant {{/str}}</option>
                <option value="graduate">{{#str}} level_graduate, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="page-length-select">
                {{#str}} target_length_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="page-length-select" class="mastermind-option-select">
                <option value="standard">{{#str}} length_standard, block_mastermind_assistant {{/str}}</option>
                <option value="brief">{{#str}} length_brief, block_mastermind_assistant {{/str}}</option>
                <option value="comprehensive">{{#str}} length_comprehensive, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
    </div>
    <button id="generate-draft-btn" class="mastermind-action-button" data-courseid="{{courseid}}" data-coursename="{{coursename}}" data-modname="{{modname}}" data-pagename="{{pagename}}" data-pagedescription="{{pagedescription}}">
        <svg class="mastermind-button-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="currentColor"/>
        </svg>
        <span>{{#str}} generate_draft, block_mastermind_assistant {{/str}}</span>
    </button>
    {{/is_on_edit_page}}{{/is_page}}
    {{#is_assign}}{{#is_on_edit_page}}
    <div class="mastermind-assign-options" id="assign-options-panel">
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="assign-type-select">
                {{#str}} assignment_type_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="assign-type-select" class="mastermind-option-select">
                <option value="">{{#str}} select_assignment_type, block_mastermind_assistant {{/str}}</option>
                <option value="essay">{{#str}} type_essay, block_mastermind_assistant {{/str}}</option>
                <option value="group_project">{{#str}} type_group_project, block_mastermind_assistant {{/str}}</option>
                <option value="presentation">{{#str}} type_presentation, block_mastermind_assistant {{/str}}</option>
                <option value="lab_report">{{#str}} type_lab_report, block_mastermind_assistant {{/str}}</option>
                <option value="case_study">{{#str}} type_case_study, block_mastermind_assistant {{/str}}</option>
                <option value="research_paper">{{#str}} type_research_paper, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="assign-level-select">
                {{#str}} academic_level_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="assign-level-select" class="mastermind-option-select">
                <option value="">{{#str}} select_academic_level, block_mastermind_assistant {{/str}}</option>
                <option value="introductory">{{#str}} level_introductory, block_mastermind_assistant {{/str}}</option>
                <option value="intermediate">{{#str}} level_intermediate, block_mastermind_assistant {{/str}}</option>
                <option value="advanced">{{#str}} level_advanced, block_mastermind_assistant {{/str}}</option>
                <option value="graduate">{{#str}} level_graduate, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="assign-scope-input">
                {{#str}} scope_length_label, block_mastermind_assistant {{/str}}
            </label>
            <input type="text" id="assign-scope-input" class="mastermind-option-input"
                   placeholder="{{#str}} scope_length_placeholder, block_mastermind_assistant {{/str}}" />
        </div>
    </div>
    <button id="generate-draft-btn" class="mastermind-action-button" data-courseid="{{courseid}}" data-coursename="{{coursename}}" data-modname="{{modname}}" data-pagename="{{pagename}}" data-pagedescription="{{pagedescription}}">
        <svg class="mastermind-button-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="currentColor"/>
        </svg>
        <span>{{#str}} generate_instructions, block_mastermind_assistant {{/str}}</span>
    </button>
    {{/is_on_edit_page}}{{/is_assign}}
    {{#is_quiz}}{{#is_on_edit_page}}
    <div class="mastermind-assign-options" id="quiz-options-panel">
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="quiz-difficulty-select">
                {{#str}} difficulty_level_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="quiz-difficulty-select" class="mastermind-option-select">
                <option value="mixed">{{#str}} difficulty_mixed, block_mastermind_assistant {{/str}}</option>
                <option value="easy">{{#str}} difficulty_easy, block_mastermind_assistant {{/str}}</option>
                <option value="medium">{{#str}} difficulty_medium, block_mastermind_assistant {{/str}}</option>
                <option value="hard">{{#str}} difficulty_hard, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="quiz-count-select">
                {{#str}} question_count_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="quiz-count-select" class="mastermind-option-select">
                <option value="6">6</option>
                <option value="8" selected>8</option>
                <option value="10">10</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="quiz-level-select">
                {{#str}} academic_level_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="quiz-level-select" class="mastermind-option-select">
                <option value="">{{#str}} select_academic_level, block_mastermind_assistant {{/str}}</option>
                <option value="introductory">{{#str}} level_introductory, block_mastermind_assistant {{/str}}</option>
                <option value="intermediate">{{#str}} level_intermediate, block_mastermind_assistant {{/str}}</option>
                <option value="advanced">{{#str}} level_advanced, block_mastermind_assistant {{/str}}</option>
                <option value="graduate">{{#str}} level_graduate, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
    </div>
    {{! Optional source-document uploader — mirrors the course-creation dropzone. }}
    <div class="mastermind-document-upload-section">
        <div class="mastermind-upload-divider">
            <span class="mastermind-divider-text">
                {{#str}} quiz_source_doc_divider, block_mastermind_assistant {{/str}}
            </span>
        </div>
        <div class="mastermind-upload-area" id="quiz-upload-area">
            <div class="mastermind-upload-dropzone" id="quiz-upload-dropzone">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 15V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V15"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="17 8 12 3 7 8"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="12" y1="3" x2="12" y2="15"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p class="mastermind-upload-text">
                    {{#str}} quiz_source_doc_prompt, block_mastermind_assistant {{/str}}
                </p>
                <p class="mastermind-upload-formats">
                    {{#str}} quiz_source_doc_hint, block_mastermind_assistant {{/str}}
                </p>
                <input type="file" id="quiz-source-doc"
                       accept=".pdf,.docx,.txt,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain"
                       style="display: none;">
                <button type="button" class="btn btn-outline-primary btn-sm" id="quiz-source-doc-btn">
                    {{#str}} choose_file, block_mastermind_assistant {{/str}}
                </button>
            </div>
            <div class="mastermind-upload-selected" id="quiz-source-doc-selected" style="display: none;">
                <div class="mastermind-selected-file">
                    <span class="mastermind-file-icon">&#128196;</span>
                    <span class="mastermind-file-name" id="quiz-source-doc-name"></span>
                    <span class="mastermind-file-size" id="quiz-source-doc-size"></span>
                    <button type="button" class="btn btn-link btn-sm mastermind-file-remove" id="quiz-source-doc-remove">
                        &times;
                    </button>
                </div>
            </div>
        </div>
    </div>
    <button id="generate-questions-btn" class="mastermind-action-button" data-courseid="{{courseid}}" data-quizid="{{quizid}}" data-quizname="{{pagename}}" data-quizdescription="{{pagedescription}}">
        <svg class="mastermind-button-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="currentColor"/>
        </svg>
        <span>{{#str}} generate_questions, block_mastermind_assistant {{/str}}</span>
    </button>
    {{/is_on_edit_page}}{{/is_quiz}}
    {{#is_forum}}{{^is_on_edit_page}}
    <div class="mastermind-assign-options" id="forum-options-panel">
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="forum-type-select">
                {{#str}} forum_type_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="forum-type-select" class="mastermind-option-select">
                <option value="general">{{#str}} forum_type_general, block_mastermind_assistant {{/str}}</option>
                <option value="single">{{#str}} forum_type_single, block_mastermind_assistant {{/str}}</option>
                <option value="qanda">{{#str}} forum_type_qanda, block_mastermind_assistant {{/str}}</option>
                <option value="eachuser">{{#str}} forum_type_eachuser, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="forum-level-select">
                {{#str}} academic_level_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="forum-level-select" class="mastermind-option-select">
                <option value="">{{#str}} select_academic_level, block_mastermind_assistant {{/str}}</option>
                <option value="introductory">{{#str}} level_introductory, block_mastermind_assistant {{/str}}</option>
                <option value="intermediate">{{#str}} level_intermediate, block_mastermind_assistant {{/str}}</option>
                <option value="advanced">{{#str}} level_advanced, block_mastermind_assistant {{/str}}</option>
                <option value="graduate">{{#str}} level_graduate, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="forum-count-select">
                {{#str}} discussion_count_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="forum-count-select" class="mastermind-option-select">
                <option value="3">3</option>
                <option value="5" selected>5</option>
                <option value="8">8</option>
                <option value="10">10</option>
            </select>
        </div>
    </div>
    <button id="generate-draft-btn" class="mastermind-action-button" data-courseid="{{courseid}}" data-coursename="{{coursename}}" data-modname="{{modname}}" data-pagename="{{pagename}}" data-pagedescription="{{pagedescription}}" data-cmid="{{cmid}}" data-instanceid="{{instanceid}}">
        <svg class="mastermind-button-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="currentColor"/>
        </svg>
        <span>{{#str}} generate_forum_content, block_mastermind_assistant {{/str}}</span>
    </button>
    {{/is_on_edit_page}}{{/is_forum}}
    {{#is_lesson}}{{^is_on_edit_page}}
    <div class="mastermind-assign-options" id="lesson-options-panel">
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="lesson-level-select">
                {{#str}} academic_level_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="lesson-level-select" class="mastermind-option-select">
                <option value="">{{#str}} select_academic_level, block_mastermind_assistant {{/str}}</option>
                <option value="introductory">{{#str}} level_introductory, block_mastermind_assistant {{/str}}</option>
                <option value="intermediate">{{#str}} level_intermediate, block_mastermind_assistant {{/str}}</option>
                <option value="advanced">{{#str}} level_advanced, block_mastermind_assistant {{/str}}</option>
                <option value="graduate">{{#str}} level_graduate, block_mastermind_assistant {{/str}}</option>
            </select>
        </div>
        <div class="mastermind-assign-option-group">
            <label class="mastermind-option-label" for="lesson-count-select">
                {{#str}} page_count_label, block_mastermind_assistant {{/str}}
            </label>
            <select id="lesson-count-select" class="mastermind-option-select">
                <option value="4">4</option>
                <option value="6" selected>6</option>
                <option value="8">8</option>
                <option value="10">10</option>
            </select>
        </div>
