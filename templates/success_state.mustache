{{!
    @template block_mastermind_assistant/success_state

    Success state template shown after content is applied.

    Context variables required for this template:
    * message - The success message to display
}}
<div class="mastermind-success-state">
    <svg class="mastermind-success-icon" width="48" height="48"
         viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
        <path d="M9 12L11 14L15 10" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <p class="mastermind-success-message">{{message}}</p>
</div>
