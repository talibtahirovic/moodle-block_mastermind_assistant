{{!
    @template block_mastermind_assistant/connect

    Locked-state UI shown when the plugin has not yet been connected.
    Site administrators see a "Connect to Mastermind" button. Other users
    see a short instructional message.

    Context variables required for this template:
    * can_configure - Boolean: true if the current user can configure plugins.

    Example context (json):
    {
        "can_configure": true
    }
}}
<div class="mastermind-connect-state">
    <div class="mastermind-connect-logo-wrap">
        <div class="mastermind-connect-logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
            </svg>
        </div>
    </div>

    <h4 class="mastermind-connect-title">{{#str}}connect_title, block_mastermind_assistant{{/str}}</h4>
    <p class="mastermind-connect-description">{{#str}}connect_description, block_mastermind_assistant{{/str}}</p>

    {{#can_configure}}
    <button type="button" id="mastermind-connect-btn" class="btn btn-primary mastermind-connect-btn">
        {{#str}}connect_button, block_mastermind_assistant{{/str}}
    </button>
    <p class="mastermind-connect-disclaimer">{{#str}}connect_free, block_mastermind_assistant{{/str}}</p>
    <div id="mastermind-connect-fallback" class="mastermind-connect-fallback" hidden></div>
    {{/can_configure}}

    {{^can_configure}}
    <div class="mastermind-connect-admin-required">
        {{#str}}connect_admin_required, block_mastermind_assistant{{/str}}
    </div>
    {{/can_configure}}
</div>
