{{!
    @template block_mastermind_assistant/site_nav

    Navigation links shown on the site home page.

    Context variables required for this template:
    * nav_links - Array of {url, label, icon} objects

    Example context (json):
    {
        "nav_links": [
            {
                "url": "/course/management.php",
                "label": "Manage courses",
                "icon": "folder"
            }
        ]
    }
}}
<div class="mastermind-site-nav-container">
    <div class="mastermind-site-nav-header">
        <h3 class="mastermind-search-title">Mastermind Assistant</h3>
    </div>
    <div class="mastermind-site-nav-links">
        {{#nav_links}}
        <a href="{{url}}" class="mastermind-site-nav-link">
            <span class="mastermind-nav-icon mastermind-nav-icon-{{icon}}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </span>
            <span class="mastermind-nav-label">{{label}}</span>
            <svg class="mastermind-nav-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
        {{/nav_links}}
    </div>
</div>
