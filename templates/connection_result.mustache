{{!
    @template block_mastermind_assistant/connection_result

    Connection test result template for settings page.

    Context variables required for this template:
    * success - Whether the connection was successful
    * tier - Account tier (when success)
    * status - Account status (when success)
    * message - Error message (when not success)

    Example context (json):
    {
        "success": true,
        "tier": "Pro",
        "status": "Active",
        "message": ""
    }
}}
{{#success}}
<div class="alert alert-success">
    <strong>&#10003; {{#str}} connection_success, block_mastermind_assistant {{/str}}</strong>
</div>
<table class="table table-sm table-bordered" style="max-width: 400px;">
    <tbody>
        <tr>
            <td><strong>{{#str}} account_tier, block_mastermind_assistant {{/str}}</strong></td>
            <td>{{tier}}</td>
        </tr>
        <tr>
            <td><strong>{{#str}} account_status, block_mastermind_assistant {{/str}}</strong></td>
            <td>{{status}}</td>
        </tr>
    </tbody>
</table>
{{/success}}
{{^success}}
<div class="alert alert-danger">
    <strong>&#10007;</strong> {{message}}
</div>
{{/success}}
